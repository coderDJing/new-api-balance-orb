{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "New API Balance Orb",
  "version": "0.1.11",
  "identifier": "com.coderdjing.aibalancewidgetnewapi",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "New API Balance Orb",
        "width": 280,
        "height": 148,
        "minWidth": 220,
        "minHeight": 148,
        "maxWidth": 520,
        "maxHeight": 2000,
        "resizable": false,
        "maximizable": false,
        "minimizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      },
      {
        "label": "settings",
        "title": "AI Balance Settings",
        "width": 440,
        "height": 540,
        "minWidth": 440,
        "minHeight": 540,
        "maxWidth": 440,
        "maxHeight": 540,
        "resizable": false,
        "maximizable": false,
        "minimizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcxRkY3MzhDRTJBOUM4RUEKUldUcXlLbmlqSFAvY1I1dnBza01hTWFXUlY2R2JqL0tQaEcrWUJKRmZ5NkYzeE45QVlpaENpdTkK",
      "endpoints": [
        "https://github.com/coderDJing/new-api-balance-orb/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
